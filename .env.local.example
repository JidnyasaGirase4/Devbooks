# Copy this file to .env.local and adjust if your XAMPP MySQL uses different creds.
# .env.local is git-ignored by Next.js by default.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=codebooks

# Admin panel — change these in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_SECRET=please-change-this-to-a-long-random-string
